# ==============================================================================
# openZero — Environment Configuration Template
# ==============================================================================
# Rename this file to .env and fill in your secrets.
# NEVER commit the actual .env file to version control. house

# The public or VPN IP address of your server.
# Used for generating dashboard and board links in briefings.
BASE_URL=http://your_server_ip_here
SERVER_IP=your_server_ip_here

# --- Remote Sync (Deployment) ---
# Used by scripts/sync.sh to push code to your VPS.
REMOTE_HOST=your_server_ip_here
REMOTE_USER=openzero
REMOTE_DIR=/home/openzero/openzero

# --- CalDAV (Private Calendar) ---
# Used for private, self-hosted calendar syncing (e.g., Nextcloud, Baikal, Radicale).
# If configured, OpenZero will fetch events and sync new ones to your private server.
# Leave CALDAV_URL empty if you only want to use Google Calendar or Local DB.
CALDAV_URL=
# Your full username or email used to log in to the CalDAV server.
CALDAV_USERNAME=
# Your password or an app-specific password if using iCloud/Nextcloud 2FA.
CALDAV_PASSWORD=

# --- Pi-hole (DNS & Ad-block) ---
# Used to access the admin dashboard at /admin
PIHOLE_PASSWORD=your_secure_dns_password

# --- Database (PostgreSQL) ---
# Used by both the backend and the Planka board.
DB_USER=zero
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD  # Create your own secure password here
DB_NAME=zero_db
DB_HOST=postgres                        # Internal Docker network name (auto-mapped to localhost in dev)
DB_PORT=5432

# --- Telegram Bot ---
# Get your token by talking to @BotFather on Telegram (https://t.me/botfather).
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your numerical Telegram User ID (e.g., 12345678). 
# Talk to @userinfobot (https://t.me/userinfobot) to find yours. 
# Only this ID can control the bot (Zero-Trust protection).
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id

# --- Time & Localization ---

# --- Local AI (llama-server / llama.cpp) ---
# openZero runs 3 llama-server containers in parallel — one per speed tier.
# Models are auto-downloaded from HuggingFace on first boot.
#
# HOW TO SWITCH HARDWARE PROFILE:
#   1. Pick a profile block below that matches your hardware.
#   2. Uncomment its lines (remove the leading #).
#   3. Comment out the currently active lines above each section.
#   4. Run: docker compose restart llm-fast llm-deep
#
# QUANTIZATION QUICK REF:
#   Q4_K_M  best size/quality ratio — default for all tiers
#   Q6_K    near-lossless, ~1.5x larger — use when RAM allows
#   Q8_0    highest quality, ~2x larger — use on homelab / Apple Silicon
#
# =========================================================================
# HARDWARE PROFILES  — pick ONE profile, uncomment its block, comment default
# =========================================================================
#
# Profile A  |  Low-RAM VPS  |  12-16 GB RAM, 4-8 vCPU
# -----------------------------------------------------------------------
# Total model RAM ~3 GB. Uses Q2_K deep model for speed on constrained RAM.
# Good for: Hetzner CX21, DigitalOcean 8 GB, cheap KVM VPS.
#
# LLM_FAST_MODEL_URL=https://huggingface.co/unsloth/Qwen3-0.6B-GGUF/resolve/main/Qwen3-0.6B-Q4_K_M.gguf
# LLM_FAST_MODEL_FILE=Qwen3-0.6B-Q4_K_M.gguf
# LLM_MODEL_FAST=Qwen3-0.6B
# LLM_FAST_THREADS=3
# LLM_FAST_CTX=2048
# LLM_FAST_PREDICT=256
# LLM_FAST_BATCH=256
# LLM_FAST_CACHE_RAM=128
#
# LLM_DEEP_MODEL_URL=https://huggingface.co/unsloth/Qwen3-8B-GGUF/resolve/main/Qwen3-8B-Q2_K.gguf
# LLM_DEEP_MODEL_FILE=Qwen3-8B-Q2_K.gguf
# LLM_MODEL_DEEP=Qwen3-8B-Q2
# LLM_DEEP_THREADS=4
# LLM_DEEP_CTX=4096
# LLM_DEEP_PREDICT=1024
# LLM_DEEP_BATCH=256
# LLM_DEEP_CACHE_RAM=512
#
# Profile B  |  Mid-Range VPS  |  24 GB RAM, 8 vCPU  — DEFAULT PROFILE
# -----------------------------------------------------------------------
# Total model RAM ~5 GB. Both tiers active.
# Good for: Hetzner CX41/CCX23, Contabo VPS-S, OVH VPS-Elite.
# (This is the default active configuration below.)
#
# Profile C  |  Dedicated Server / Homelab NUC  |  32 GB RAM, 8-12 cores
# -----------------------------------------------------------------------
# Upgraded quants for better quality; wider context windows.
# Good for: Intel NUC 12/13 Pro, Minisforum UM790, HP Elitedesk 800.
#
# LLM_FAST_MODEL_URL=https://huggingface.co/unsloth/Qwen3-1.7B-GGUF/resolve/main/Qwen3-1.7B-Q8_0.gguf
# LLM_FAST_MODEL_FILE=Qwen3-1.7B-Q8_0.gguf
# LLM_MODEL_FAST=Qwen3-1.7B-Q8
# LLM_FAST_THREADS=4
# LLM_FAST_CTX=4096
# LLM_FAST_PREDICT=512
# LLM_FAST_BATCH=512
# LLM_FAST_CACHE_RAM=256
#
# LLM_DEEP_MODEL_URL=https://huggingface.co/unsloth/Qwen3-14B-GGUF/resolve/main/Qwen3-14B-Q6_K.gguf
# LLM_DEEP_MODEL_FILE=Qwen3-14B-Q6_K.gguf
# LLM_MODEL_DEEP=Qwen3-14B-Q6
# LLM_DEEP_THREADS=10
# LLM_DEEP_CTX=8192
# LLM_DEEP_PREDICT=2048
# LLM_DEEP_BATCH=512
# LLM_DEEP_CACHE_RAM=2048
#
# Profile D  |  Mac Mini / Apple Silicon  |  24-64 GB unified RAM
# -----------------------------------------------------------------------
# High-quality quants; wide context. Runs cool and efficient on M-series.
# Good for: Mac Mini M2/M4, MacBook Pro M3/M4, Mac Studio.
# Note: llama.cpp uses Metal automatically — no GPU_LAYERS needed on Apple.
#
# LLM_FAST_MODEL_URL=https://huggingface.co/unsloth/Qwen3-1.7B-GGUF/resolve/main/Qwen3-1.7B-Q8_0.gguf
# LLM_FAST_MODEL_FILE=Qwen3-1.7B-Q8_0.gguf
# LLM_MODEL_FAST=Qwen3-1.7B-Q8
# LLM_FAST_THREADS=4
# LLM_FAST_CTX=4096
# LLM_FAST_PREDICT=512
# LLM_FAST_BATCH=512
# LLM_FAST_CACHE_RAM=512
#
# LLM_DEEP_MODEL_URL=https://huggingface.co/unsloth/Qwen3-32B-GGUF/resolve/main/Qwen3-32B-Q4_K_M.gguf
# LLM_DEEP_MODEL_FILE=Qwen3-32B-Q4_K_M.gguf
# LLM_MODEL_DEEP=Qwen3-32B
# LLM_DEEP_THREADS=12
# LLM_DEEP_CTX=16384
# LLM_DEEP_PREDICT=4096
# LLM_DEEP_BATCH=512
# LLM_DEEP_CACHE_RAM=4096
#
# Profile E  |  GPU Server / High-Memory VPS  |  RTX 3090/4090 or 64 GB+ RAM
# -----------------------------------------------------------------------
# All layers offloaded to VRAM — near-fast responses on all tiers.
# Good for: Lambda/RunPod GPU instances, self-hosted RTX workstation.
#
# LLM_FAST_MODEL_URL=https://huggingface.co/unsloth/Qwen3-1.7B-GGUF/resolve/main/Qwen3-1.7B-Q8_0.gguf
# LLM_FAST_MODEL_FILE=Qwen3-1.7B-Q8_0.gguf
# LLM_MODEL_FAST=Qwen3-1.7B-Q8
# LLM_FAST_THREADS=4
# LLM_FAST_CTX=8192
# LLM_FAST_PREDICT=512
# LLM_FAST_BATCH=512
# LLM_FAST_GPU_LAYERS=99
#
# LLM_DEEP_MODEL_URL=https://huggingface.co/bartowski/Meta-Llama-3.1-70B-Instruct-GGUF/resolve/main/Meta-Llama-3.1-70B-Instruct-Q4_K_M.gguf
# LLM_DEEP_MODEL_FILE=Meta-Llama-3.1-70B-Instruct-Q4_K_M.gguf
# LLM_MODEL_DEEP=Llama-3.1-70B
# LLM_DEEP_THREADS=4               # same reasoning — GPU-bound; more CPU threads add no throughput
# LLM_DEEP_CTX=16384
# LLM_DEEP_PREDICT=4096
# LLM_DEEP_BATCH=512
# LLM_DEEP_GPU_LAYERS=99
# LLM_DEEP_CACHE_RAM=4096
#
# =========================================================================
# ACTIVE CONFIGURATION  — Profile B (Mid-Range VPS, 24 GB RAM)
# Change the values below or replace with an uncommented profile block above.
# =========================================================================

# -----------------------------------------------------------------------
# FAST TIER — greetings, confirmations, memory distillation  (<2s)
# -----------------------------------------------------------------------
LLM_FAST_MODEL_URL=https://huggingface.co/unsloth/Qwen3-0.6B-GGUF/resolve/main/Qwen3-0.6B-Q4_K_M.gguf
LLM_FAST_MODEL_FILE=Qwen3-0.6B-Q4_K_M.gguf
LLM_MODEL_FAST=Qwen3-0.6B

# -----------------------------------------------------------------------
# DEEP TIER — complex analysis, planning, creative writing  (10-30s streaming)
# -----------------------------------------------------------------------
LLM_DEEP_MODEL_URL=https://huggingface.co/unsloth/Qwen3-8B-GGUF/resolve/main/Qwen3-8B-Q3_K_M.gguf
LLM_DEEP_MODEL_FILE=Qwen3-8B-Q3_K_M.gguf
LLM_MODEL_DEEP=Qwen3-8B-Q3

# -----------------------------------------------------------------------
# Internal Docker network URLs — do not change unless custom networking
# -----------------------------------------------------------------------
LLM_FAST_URL=http://llm-fast:8081
LLM_DEEP_URL=http://llm-deep:8083

# -----------------------------------------------------------------------
# Performance tuning — threads, context, prediction, batch
# Threads: For an 8-core VPS, 4 threads is usually the sweet spot. 
# Going higher (e.g., 7 or 8) often degrades throughput because llama.cpp 
# inference is memory-bandwidth-bound, and full CPU saturation causes context
# switching overhead with other containers (backend, db, fast-tier).
# GPU note: when GPU_LAYERS=99, the GPU handles all matrix math — CPU threads only
# drive prompt tokenisation and sampling.  4 threads is enough; more is wasted.
# Ctx: tokens held in memory window per request.
# -----------------------------------------------------------------------
LLM_FAST_THREADS=4
LLM_DEEP_THREADS=4
LLM_FAST_CTX=4096
LLM_DEEP_CTX=6144
LLM_FAST_PREDICT=256
LLM_DEEP_PREDICT=4096

# Batch size (higher = faster first token, more RAM). 512 is a safe default.
LLM_FAST_BATCH=512
LLM_DEEP_BATCH=256

# Cache RAM limit (MiB). Exposing this ensures llama-server does not default 
# to a massive 8 GB prompt cache that causes memory bloat.
LLM_FAST_CACHE_RAM=256
LLM_DEEP_CACHE_RAM=1024

# Deep tier timeout (seconds) — fast falls back to deep on timeout
DEEP_MODEL_TIMEOUT_S=60

# GPU offloading (layers: 0 = CPU only, 99 = all layers to GPU)
# LLM_FAST_GPU_LAYERS=0
# LLM_DEEP_GPU_LAYERS=0

# --- Local Voice Transcription (Whisper) ---
# The internal URL for the whisper-asr container.
WHISPER_BASE_URL=http://whisper:9000    # Internal Docker URL (auto-mapped to localhost in dev)

# --- Vector Memory (Qdrant) ---
# Qdrant stores your semantic memories and notes.
QDRANT_HOST=qdrant                       # Internal Docker name (auto-mapped to localhost in dev)
QDRANT_PORT=6333
# Create your own unique API key here for security.
QDRANT_API_KEY=CHANGE_ME_QDRANT_KEY

# --- Task Queue (Redis) ---
# Redis is used for the background task queue. It requires a password.
# Generate one with: openssl rand -hex 24
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Task Board (Planka) ---
# The internal URL where the backend can find Planka.
PLANKA_BASE_URL=http://planka:1337       # Internal Docker URL (auto-mapped to localhost in dev)
# Default credentials created on first launch. 
# You will use these to log into the Planka PWA.
PLANKA_ADMIN_EMAIL=admin@example.com
PLANKA_ADMIN_PASSWORD=CHANGE_ME_PLANKA_PASS

# --- Intelligence Layer Settings ---
# Default chat provider.
# Options: local (llama-server, free), groq (cloud, fast), openai (cloud, advanced)
LLM_PROVIDER=local

# --- Cloud LLM Keys (Optional) ---
# Get your Groq API key from: https://console.groq.com/keys
GROQ_API_KEY=
# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Deep Thinking (/think command) ---
# Which provider to use for high-power reasoning.
# NOTE: These models run in the cloud (Groq/OpenAI), not on your VPS. 
# They are extremely fast but require an API key.
# LEAVE BLANK to disable the /think command.
DEEP_THINK_PROVIDER=
# The specific model for deep reasoning. 
# Options for Groq: llama-3.3-70b-specdec, llama3-70b-8192
# Options for OpenAI: o1-mini, gpt-4o
DEEP_THINK_MODEL=

# --- Privacy: Cloud LLM PII Sanitization ---
# When enabled, outbound prompts sent to cloud providers (Groq, OpenAI) are
# stripped of named entities (people, locations, emails, phone numbers, orgs)
# using a fully offline spaCy NER model before leaving the VPS.
# Responses are re-hydrated back to real values before returning to callers.
# The en_core_web_sm model (~12 MB) is baked into the Docker image at build time.
# Set to false only to disable globally (e.g. for debugging / non-personal payloads).
CLOUD_LLM_SANITIZE=true

# --- Dify Crews & Orchestration ---
# The internal URL where the backend can find the Dify API.
DIFY_API_URL=http://dify-api:5001/v1
# Your Dify Workspace API Key (Required for Auto-Provisioning).
DIFY_API_KEY=
# A secure random string protecting your internal webhook callbacks.
# Generate one with: openssl rand -hex 24
INTEGRATION_TOKEN=require_me_in_production

# --- Briefing Settings ---
# Include a rotating "Calibration" micro-exercise in the morning briefing.
# Methods rotate between: gratitude, intention-setting, reframing, breathwork, visualization.
# Set to false to disable.
BRIEFING_CALIBRATION=true
