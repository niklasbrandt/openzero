# ==============================================================================
# OpenZero — Environment Configuration Template
# ==============================================================================
# Rename this file to .env and fill in your secrets.
# NEVER commit the actual .env file to version control. house

# The public or VPN IP address of your server.
# Used for generating dashboard and board links in briefings.
BASE_URL=http://your_server_ip_here
SERVER_IP=your_server_ip_here

# --- Remote Sync (Deployment) ---
# Used by scripts/sync.sh to push code to your VPS.
REMOTE_HOST=your_server_ip_here
REMOTE_USER=openzero
REMOTE_DIR=/home/openzero/openzero

# --- CalDAV (Private Calendar) ---
# Used for private, self-hosted calendar syncing (e.g., Nextcloud, Baikal, Radicale).
# If configured, OpenZero will fetch events and sync new ones to your private server.
# Leave CALDAV_URL empty if you only want to use Google Calendar or Local DB.
CALDAV_URL=
# Your full username or email used to log in to the CalDAV server.
CALDAV_USERNAME=
# Your password or an app-specific password if using iCloud/Nextcloud 2FA.
CALDAV_PASSWORD=

# --- Pi-hole (DNS & Ad-block) ---
# Used to access the admin dashboard at /admin
PIHOLE_PASSWORD=your_secure_dns_password

# --- Database (PostgreSQL) ---
# Used by both the backend and the Planka board.
DB_USER=zero
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD  # Create your own secure password here
DB_NAME=zero_db
DB_HOST=postgres                        # Internal Docker network name (auto-mapped to localhost in dev)
DB_PORT=5432

# --- Telegram Bot ---
# Get your token by talking to @BotFather on Telegram (https://t.me/botfather).
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your numerical Telegram User ID (e.g., 12345678). 
# Talk to @userinfobot (https://t.me/userinfobot) to find yours. 
# Only this ID can control the bot (Zero-Trust protection).
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id

# --- Time & Localization ---

# --- Local AI (llama-server / llama.cpp) ---
# openZero uses a 3-tier local LLM architecture with llama-server (llama.cpp).
# Each tier runs as a separate Docker container for parallel availability.
#
# TIER OVERVIEW:
#   Instant  (port 8081) - Greetings, confirmations, memory distillation (<2s)
#   Standard (port 8082) - Normal conversation, moderate reasoning (3-8s streaming)
#   Deep     (port 8083) - Complex analysis, planning, creative writing (10-30s streaming)
#
# -----------------------------------------------------------------------
# HARDWARE SIZING GUIDE
# -----------------------------------------------------------------------
#
# 16 GB RAM (tight - disable deep tier):
#   Instant:  phi-4-mini Q4_0          (~2.5 GB)   4 threads, 2048 ctx
#   Standard: llama3.1:8b Q4_0         (~5 GB)     4 threads, 4096 ctx
#   Deep:     DISABLED (set LLM_DEEP_URL same as standard)
#   Free RAM for OS + services: ~7 GB
#
# 24 GB RAM (recommended minimum):
#   Instant:  phi-4-mini Q4_0          (~2.5 GB)   4 threads, 2048 ctx
#   Standard: llama3.1:8b Q4_0         (~5 GB)     4 threads, 4096 ctx
#   Deep:     qwen2.5:14b Q4_K_M       (~9.5 GB)   6 threads, 4096 ctx
#   Free RAM for OS + services: ~3.5 GB
#
# 32 GB RAM (comfortable):
#   Instant:  phi-4-mini Q4_K_M        (~2.8 GB)   4 threads, 2048 ctx
#   Standard: llama3.1:8b Q4_K_M       (~5.5 GB)   6 threads, 8192 ctx
#   Deep:     qwen2.5:14b Q6_K         (~12 GB)    8 threads, 8192 ctx
#   Free RAM for OS + services: ~8 GB
#
# 64 GB RAM / Apple Silicon (luxury):
#   Instant:  phi-4-mini Q8_0          (~4 GB)     4 threads, 4096 ctx
#   Standard: llama3.1:8b Q8_0         (~9 GB)     8 threads, 8192 ctx
#   Deep:     qwen2.5:14b Q8_0         (~16 GB)    12 threads, 16384 ctx
#   Or swap deep for a 32B model at Q4_K_M (~20 GB)
#
# GPU VPS (e.g. RTX 3090/4090):
#   Add -ngl 99 to MODEL_EXTRA_FLAGS to offload all layers to GPU.
#   Most 14B models will fully fit in 24 GB VRAM at Q4_K_M.
#
# QUANTIZATION CHEAT SHEET:
#   Q4_0     - Smallest, fastest, lowest quality. Good for instant tier.
#   Q4_K_M   - Best quality/size ratio. Recommended default.
#   Q6_K     - Near-lossless. Use if RAM allows.
#   Q8_0     - Highest quality. ~2x the size of Q4_K_M.
#
# THREAD GUIDE:
#   Set to physical CPU cores (not hyperthreads).
#   Leave 2 cores free for the OS and other services.
#   Example: 8-core CPU -> 6 threads for standard, 4 for instant.
# -----------------------------------------------------------------------

# Model download URLs (HuggingFace GGUF files)
# The entrypoint auto-downloads on first boot.
LLM_INSTANT_MODEL_URL=https://huggingface.co/microsoft/phi-4-mini-instruct-gguf/resolve/main/phi-4-mini-instruct-q4.gguf
LLM_INSTANT_MODEL_FILE=phi-4-mini-instruct-q4.gguf
LLM_STANDARD_MODEL_URL=https://huggingface.co/bartowski/Meta-Llama-3.1-8B-Instruct-GGUF/resolve/main/Meta-Llama-3.1-8B-Instruct-Q4_0.gguf
LLM_STANDARD_MODEL_FILE=Meta-Llama-3.1-8B-Instruct-Q4_0.gguf
LLM_DEEP_MODEL_URL=https://huggingface.co/bartowski/Qwen2.5-14B-Instruct-GGUF/resolve/main/Qwen2.5-14B-Instruct-Q4_K_M.gguf
LLM_DEEP_MODEL_FILE=Qwen2.5-14B-Instruct-Q4_K_M.gguf

# Internal Docker URLs (do not change unless custom networking)
LLM_INSTANT_URL=http://llm-instant:8081
LLM_STANDARD_URL=http://llm-standard:8082
LLM_DEEP_URL=http://llm-deep:8083

# Display names (shown in status/footer)
LLM_MODEL_INSTANT=phi-4-mini
LLM_MODEL_STANDARD=llama3.1:8b
LLM_MODEL_DEEP=qwen2.5:14b

# Performance tuning
LLM_INSTANT_THREADS=4
LLM_STANDARD_THREADS=4
LLM_DEEP_THREADS=6
LLM_INSTANT_CTX=2048
LLM_STANDARD_CTX=4096
LLM_DEEP_CTX=4096
LLM_INSTANT_PREDICT=256
LLM_STANDARD_PREDICT=1024
LLM_DEEP_PREDICT=2048

# Deep tier timeout (seconds) - falls back to standard if first token takes longer
DEEP_MODEL_TIMEOUT_S=12

# GPU offloading (set layers to offload; 0 = CPU only, 99 = all layers)
# LLM_INSTANT_GPU_LAYERS=0
# LLM_STANDARD_GPU_LAYERS=0
# LLM_DEEP_GPU_LAYERS=0

# --- Local Voice Transcription (Whisper) ---
# The internal URL for the whisper-asr container.
WHISPER_BASE_URL=http://whisper:9000    # Internal Docker URL (auto-mapped to localhost in dev)

# --- Vector Memory (Qdrant) ---
# Qdrant stores your semantic memories and notes.
QDRANT_HOST=qdrant                       # Internal Docker name (auto-mapped to localhost in dev)
QDRANT_PORT=6333
# Create your own unique API key here for security.
QDRANT_API_KEY=CHANGE_ME_QDRANT_KEY

# --- Task Board (Planka) ---
# The internal URL where the backend can find Planka.
PLANKA_BASE_URL=http://planka:1337       # Internal Docker URL (auto-mapped to localhost in dev)
# Default credentials created on first launch. 
# You will use these to log into the Planka PWA.
PLANKA_ADMIN_EMAIL=admin@example.com
PLANKA_ADMIN_PASSWORD=CHANGE_ME_PLANKA_PASS

# --- Intelligence Layer Settings ---
# Default provider for standard chat interactions.
# Options: local (llama-server, free), groq (cloud, fast), openai (cloud, advanced)
LLM_PROVIDER=local

# --- Cloud LLM Keys (Optional) ---
# Get your Groq API key from: https://console.groq.com/keys
GROQ_API_KEY=
# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Deep Thinking (/think command) ---
# Which provider to use for high-power reasoning.
# NOTE: These models run in the cloud (Groq/OpenAI), not on your VPS. 
# They are extremely fast but require an API key.
# LEAVE BLANK to disable the /think command.
DEEP_THINK_PROVIDER=
# The specific model for deep reasoning. 
# Options for Groq: llama-3.3-70b-specdec, llama3-70b-8192
# Options for OpenAI: o1-mini, gpt-4o
DEEP_THINK_MODEL=

# --- Briefing Settings ---
# Include a rotating "Calibration" micro-exercise in the morning briefing.
# Methods rotate between: gratitude, intention-setting, reframing, breathwork, visualization.
# Set to false to disable.
BRIEFING_CALIBRATION=true
