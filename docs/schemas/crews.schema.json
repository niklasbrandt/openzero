{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "openZero Crew Configuration Schema",
	"type": "object",
	"properties": {
		"crew_lead_time_minutes": {
			"type": "integer",
			"default": 90,
			"description": "How many minutes before briefing time crews should start by default."
		},
		"crews": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/CrewConfig"
			}
		}
	},
	"required": [
		"crews"
	],
	"definitions": {
		"CrewCharacter": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string"
				},
				"role": {
					"type": "string"
				},
				"instructions": {
					"type": "string"
				}
			},
			"required": [
				"name",
				"role"
			]
		},
		"CrewConfig": {
			"type": "object",
			"properties": {
				"id": {
					"type": "string",
					"pattern": "^[a-zA-Z0-9_-]+$"
				},
				"name": {
					"type": "string"
				},
				"description": {
					"type": "string"
				},
				"group": {
					"type": "string",
					"enum": ["basic", "business", "education", "private"]
				},
				"instructions": {
					"type": "string",
					"description": "Multi-line instruction block for the LLM."
				},
				"type": {
					"type": "string",
					"enum": [
						"workflow",
						"agent"
					]
				},
				"enabled": {
					"type": "boolean",
					"default": true
				},
				"feeds_briefing": {
					"type": "string",
					"enum": [
						"/day",
						"/week",
						"/month",
						"/quarter",
						"/year"
					]
				},
				"briefing_day": {
					"type": "string",
					"enum": [
						"MON",
						"TUE",
						"WED",
						"THU",
						"FRI",
						"SAT",
						"SUN"
					]
				},
				"briefing_dom": {
					"description": "Day-of-month for /month cadence. Integer or comma string e.g. 1, 15, '1,15'."
				},
				"briefing_months": {
					"type": "string",
					"description": "Comma-separated month numbers for /quarter cadence e.g. '1,4,7,10'."
				},
				"lead_time": {
					"type": "integer",
					"description": "Per-crew override for minutes before briefing time."
				},
				"schedule": {
					"type": "string",
					"description": "Crontab expression (5 fields)"
				},
				"planka_board": {
					"type": "string"
				},
				"planka_lists": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"characters": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/CrewCharacter"
					}
				},
				"keywords": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Words/phrases that trigger automatic routing of free-text messages to this crew."
				},
				"panels": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Crew IDs that run alongside this crew."
				},
				"panel_exclude": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Crew IDs that are explicitly blocked from co-running in panels with this crew."
				}
			},
			"required": [
				"id",
				"name",
				"type"
			]
		}
	}
}
